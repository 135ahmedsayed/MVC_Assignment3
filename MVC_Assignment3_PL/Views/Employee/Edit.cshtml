@model EmployeeUpdateRequest
@inject IMapper mapper
@{
    ViewData["Title"] = "Edit";
}

<div class="row justify-content-center align-content-center mt-3">
    <h1 class="col-8 my-4">Edit Employee</h1>
    <form method="post" asp-controller="Employee" asp-action="Edit" class="col-8">
        @* Partial *@
        <partial name="Partials/CreateEditPartial" model="mapper.Map<EmployeeRequest>(Model)" />

        <div class="mt-4 m-auto">
            <input class="btn btn-success" type="submit" value="Edit" />
            <a asp-controller="Employee" asp-action="Index" class="btn btn-outline-dark">Back to list</a>
        </div>
    </form>
</div>
